# Supabase (Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_ANON_PUBLIC_KEY

# Service role key — 只在後端 (webhook / server route) 使用,絕不能放到前端 bundle
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 前台預設店家 slug (單店 demo 用,之後改子網域)
NUXT_PUBLIC_DEFAULT_TENANT_SLUG=demo-shop

# Email (Resend) — server only
# 沒設 → dev mode, 只 console.log 不真寄
RESEND_API_KEY=
# 寄件人 email; 沒驗證網域時用內建 onboarding@resend.dev
EMAIL_FROM=onboarding@resend.dev
